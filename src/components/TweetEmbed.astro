<slot/>
<script is:inline>
    if(window.Promise != null && document.getElementById("tweet-script") == null) {
        var tweetScript = document.createElement("script");
        tweetScript.src = "//platform.twitter.com/widgets.js";
        tweetScript.id = "tweet-script"
        tweetScript.setAttribute("async", true);
        document.body.appendChild(tweetScript);
    }
</script>
